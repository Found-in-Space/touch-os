{
  "name": "@found-in-space/touch-os",
  "version": "0.2.0-dev.0",
  "description": "A virtual-device UI runtime for shared surfaces in games, XR, simulations, and 3D apps.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Found-in-Space/touch-os.git"
  },
  "homepage": "https://github.com/Found-in-Space/touch-os#readme",
  "bugs": {
    "url": "https://github.com/Found-in-Space/touch-os/issues"
  },
  "keywords": [
    "ui",
    "runtime",
    "virtual-device",
    "threejs",
    "xr",
    "headless"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./containers": {
      "types": "./dist/containers/index.d.ts",
      "import": "./dist/containers/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./hosts": {
      "types": "./dist/hosts/index.d.ts",
      "import": "./dist/hosts/index.js"
    },
    "./hosts/three": {
      "types": "./dist/hosts/three.d.ts",
      "import": "./dist/hosts/three.js"
    },
    "./adapters/schema": {
      "types": "./dist/adapters/schema.d.ts",
      "import": "./dist/adapters/schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "vite examples/three-living-room --host 0.0.0.0",
    "example:build": "vite build examples/three-living-room",
    "example:living-room": "vite examples/three-living-room --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "three": ">=0.170.0 <1"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/three": "^0.180.0",
    "three": "^0.180.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
